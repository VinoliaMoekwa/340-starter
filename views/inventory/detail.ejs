<%# Unit 3, Assignment 3, Task 1 %>
<% if (title) { %>
  <h1><%= title %></h1>
<% } else { %>
  <% res.redirect("/") %>
<% } %>

<% if (Object.entries(htmlData).length > 0) { %>
  <%- htmlData %>

  <% if (locals.loggedin) { %>
    <div class="favorite-action">
      <button id="favorite-toggle" data-inv-id="<%= vehicle.inv_id %>">
        Add / Remove Favorite
      </button>
    </div>
  <% } else { %>
    <p class="notice">
      <a href="/account/login">Log in</a> to add or remove this vehicle from your favorites.
    </p>
  <% } %>

<% } else { %>
  <p class="notice">Sorry, no matching vehicle could be found.</p>
<% } %>

<script src="/js/detail-favorites.js"></script>