<%- include("../partials/header") %>

<div class="favorites-page">

  <h1><%= title %></h1>

  <% if (messages && messages.notice) { %>
    <p class="notice"><%= messages.notice %></p>
  <% } %>

  <div class="favorites-count">
    <% if (favoriteCount === 0) { %>
      <p>You haven't added any favorites yet.</p>
    <% } else if (favoriteCount === 1) { %>
      <p>You have 1 favorite vehicle.</p>
    <% } else { %>
      <p>You have <%= favoriteCount %> favorite vehicles.</p>
    <% } %>
  </div>

  <% if (favoriteCount > 0) { %>

    <div class="favorites-grid">

      <% favorites.forEach(vehicle => { %>
        <div class="favorite-card">

          <img src="<%= vehicle.inv_thumbnail %>" alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>">

          <div class="favorite-info">
            <h3><%= vehicle.inv_make %> <%= vehicle.inv_model %></h3>
            <p><%= vehicle.inv_price %></p>

            <a href="/inv/detail/<%= vehicle.inv_id %>">View Details</a>

            <button
              class="btn-remove"
              data-inv-id="<%= vehicle.inv_id %>">
              Remove
            </button>

          </div>

        </div>
      <% }) %>

    </div>

    <a href="/inv/" class="btn-browse">Browse More Vehicles</a>

  <% } else { %>

    <div class="empty-state">
      <h2>❤️ Your favorites list is empty</h2>
      <p>Start adding vehicles you love to your favorites!</p>
      <a href="/inv/" class="btn-browse">Browse Vehicles</a>
    </div>

  <% } %>

</div>

<!-- IMPORTANT: external JS ONLY -->
<script src="/js/favorites.js"></script>

<%- include("../partials/footer") %>